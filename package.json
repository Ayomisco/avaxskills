  "openskills": {
    "registry": "Ayomisco/avaxskills",
    "version": "2.0.0",
    "skillsDir": "skills/",
    "rootSkill": "SKILL.md",
    "discovery": {
      "llmsTxt": "llms.txt",
      "sitemap": "sitemap.xml",
      "api": "https://avaxskills.com/api/skills.json"
    },
    "tiers": {
      "0": "Beginner Onramp",
      "1": "EVM Core",
      "2": "Avalanche Unique",
      "3": "Ecosystem Intelligence",
      "4": "Quality & Process",
      "5": "Positioning",
      "6": "Advanced Pro"
