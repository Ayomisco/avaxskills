  "files": [
    "skills/",
    "SKILL.md",
    "AGENTS.md",
    "llms.txt",
    "sitemap.xml",
    "README.md"
  ],
  "scripts": {
    "validate": "npx ts-node scripts/validate-skill.ts",
    "package": "bash scripts/package-skills.sh",
    "index": "npx ts-node scripts/generate-index.ts"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.0",
